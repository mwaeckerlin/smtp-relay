{
  "name": "@mwaeckerlin/smtp-relay",
  "version": "1.1.0",
  "scripts": {
    "build": "docker compose build",
    "start": "docker compose up --build --force-recreate --remove-orphans",
    "start:daemon": "docker compose up -d --build --force-recreate --remove-orphans",
    "stop": "docker compose down",
    "test": "npm run test:image && npm run test:config",
    "test:image": "npm run build && bash tests/image-contract.sh mwaeckerlin/smtp-relay",
    "test:config": "bash tests/config-validation.sh mwaeckerlin/smtp-relay"
  }
}
